import com.example.ai_develop.domain.AgentStage;
import kotlin.Boolean;

CREATE TABLE IF NOT EXISTS AgentStateEntity (
    agentId TEXT NOT NULL PRIMARY KEY,
    name TEXT NOT NULL DEFAULT '',
    systemPrompt TEXT NOT NULL DEFAULT 'You are a helpful assistant.',
    temperature REAL NOT NULL DEFAULT 0.7,
    maxTokens INTEGER NOT NULL DEFAULT 2000,
    stopWord TEXT NOT NULL DEFAULT '',
    currentStage TEXT AS AgentStage NOT NULL DEFAULT 'PLANNING',
    currentStepId TEXT,
    planJson TEXT NOT NULL, -- JSON AgentPlan
    memoryStrategyJson TEXT NOT NULL DEFAULT '', -- JSON ChatMemoryStrategy
    workingMemoryJson TEXT NOT NULL DEFAULT '', -- JSON WorkingMemory
    llmProviderJson TEXT, -- JSON LLMProvider (основная модель чата)
    ragEnabled INTEGER AS Boolean NOT NULL DEFAULT 0,
    mcpAllowedBindingIdsJson TEXT NOT NULL DEFAULT '[]',
    workflowStagesEnabled INTEGER AS Boolean NOT NULL DEFAULT 1
);

CREATE TABLE IF NOT EXISTS ProfileEntity (
    agentId TEXT NOT NULL PRIMARY KEY,
    preferences TEXT NOT NULL,
    constraints TEXT NOT NULL,
    memoryModelProviderJson TEXT -- JSON LLMProvider
);

CREATE TABLE IF NOT EXISTS InvariantEntity (
    id TEXT NOT NULL PRIMARY KEY,
    agentId TEXT NOT NULL,
    rule TEXT NOT NULL,
    stage TEXT AS AgentStage NOT NULL,
    isActive INTEGER AS Boolean NOT NULL DEFAULT 1,
    FOREIGN KEY(agentId) REFERENCES AgentStateEntity(agentId) ON DELETE CASCADE
);

CREATE TABLE IF NOT EXISTS AgentMessageEntity (
    id TEXT NOT NULL PRIMARY KEY,
    agentId TEXT NOT NULL,
    stage TEXT AS AgentStage NOT NULL,
    stepId TEXT,
    role TEXT NOT NULL,
    content TEXT NOT NULL,
    timestamp INTEGER NOT NULL,
    taskId TEXT, -- Ссылка на задачу, если сообщение относится к ней
    llmSnapshotJson TEXT, -- JSON LlmRequestSnapshot для отладки
    FOREIGN KEY(agentId) REFERENCES AgentStateEntity(agentId) ON DELETE CASCADE
);

CREATE TABLE IF NOT EXISTS TaskEntity (
    taskId TEXT NOT NULL PRIMARY KEY,
    title TEXT NOT NULL,
    taskState TEXT NOT NULL, -- TaskState enum name
    isPaused INTEGER AS Boolean NOT NULL DEFAULT 0,
    isStarted INTEGER AS Boolean NOT NULL DEFAULT 0,
    step INTEGER NOT NULL DEFAULT 0,
    planJson TEXT NOT NULL, -- JSON List<String>
    planDoneJson TEXT NOT NULL, -- JSON List<String>
    currentPlanStep TEXT,
    totalCount INTEGER NOT NULL DEFAULT 0,
    architectAgentId TEXT,
    executorAgentId TEXT,
    validatorAgentId TEXT,
    architectColor INTEGER NOT NULL DEFAULT 0,
    executorColor INTEGER NOT NULL DEFAULT 0,
    validatorColor INTEGER NOT NULL DEFAULT 0,
    createdAt INTEGER NOT NULL,
    runtimeStateJson TEXT NOT NULL DEFAULT '{}'
);

-- Queries
saveAgentState:
INSERT OR REPLACE INTO AgentStateEntity(
    agentId, name, systemPrompt, temperature, maxTokens, stopWord,
    currentStage, currentStepId, planJson, memoryStrategyJson, workingMemoryJson, llmProviderJson, ragEnabled,
    mcpAllowedBindingIdsJson, workflowStagesEnabled
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getAgentState:
SELECT * FROM AgentStateEntity WHERE agentId = ?;

getAllAgents:
SELECT * FROM AgentStateEntity;

saveProfile:
INSERT OR REPLACE INTO ProfileEntity(agentId, preferences, constraints, memoryModelProviderJson)
VALUES (?, ?, ?, ?);

getProfile:
SELECT * FROM ProfileEntity WHERE agentId = ?;

insertInvariant:
INSERT OR REPLACE INTO InvariantEntity(id, agentId, rule, stage, isActive)
VALUES (?, ?, ?, ?, ?);

getInvariantsForStage:
SELECT * FROM InvariantEntity WHERE agentId = ? AND stage = ? AND isActive = 1;

insertMessage:
INSERT OR REPLACE INTO AgentMessageEntity(id, agentId, stage, stepId, role, content, timestamp, taskId, llmSnapshotJson)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

getMessagesForAgent:
SELECT * FROM AgentMessageEntity WHERE agentId = ? ORDER BY timestamp ASC;

getMessagesForTask:
SELECT * FROM AgentMessageEntity WHERE taskId = ? ORDER BY timestamp ASC;

deleteMessagesForTask:
DELETE FROM AgentMessageEntity WHERE taskId = ?;

deleteMessagesForAgent:
DELETE FROM AgentMessageEntity WHERE agentId = ?;

deleteAgent:
DELETE FROM AgentStateEntity WHERE agentId = ?;

-- Task Queries
saveTask:
INSERT OR REPLACE INTO TaskEntity(
    taskId, title, taskState, isPaused, isStarted, step, planJson, planDoneJson,
    currentPlanStep, totalCount, architectAgentId, executorAgentId,
    validatorAgentId, architectColor, executorColor, validatorColor, createdAt,
    runtimeStateJson
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getTask:
SELECT * FROM TaskEntity WHERE taskId = ?;

getAllTasks:
SELECT * FROM TaskEntity ORDER BY createdAt DESC;

deleteTask:
DELETE FROM TaskEntity WHERE taskId = ?;

-- После перезапуска приложения автономный конвейер не продолжается, пока пользователь не нажмёт «продолжить».
pauseAllTasksOnAppLaunch:
UPDATE TaskEntity SET isPaused = 1;

-- MCP: зарегистрированные серверы (Streamable HTTP endpoint)
CREATE TABLE IF NOT EXISTS McpServerEntity (
    id TEXT NOT NULL PRIMARY KEY,
    displayName TEXT NOT NULL,
    baseUrl TEXT NOT NULL,
    enabled INTEGER AS Boolean NOT NULL DEFAULT 1,
    headersJson TEXT NOT NULL DEFAULT '{}',
    lastSyncToolsJson TEXT NOT NULL DEFAULT '',
    lastSyncError TEXT,
    lastSyncAt INTEGER NOT NULL DEFAULT 0,
    deploymentKind TEXT NOT NULL DEFAULT 'REMOTE',
    startCommand TEXT NOT NULL DEFAULT '',
    linkStatus TEXT NOT NULL DEFAULT 'UNKNOWN',
    wireKind TEXT NOT NULL DEFAULT 'STREAMABLE_HTTP'
);

-- Инструменты MCP: заполняются только синхронизацией listTools (вкл/выкл вручную)
CREATE TABLE IF NOT EXISTS McpToolBindingEntity (
    id TEXT NOT NULL PRIMARY KEY,
    serverId TEXT NOT NULL,
    mcpToolName TEXT NOT NULL,
    description TEXT NOT NULL DEFAULT '',
    inputSchemaJson TEXT NOT NULL DEFAULT '{}',
    enabled INTEGER AS Boolean NOT NULL DEFAULT 0,
    FOREIGN KEY(serverId) REFERENCES McpServerEntity(id) ON DELETE CASCADE,
    UNIQUE(serverId, mcpToolName)
);

CREATE INDEX IF NOT EXISTS idx_mcp_binding_server ON McpToolBindingEntity(serverId);

insertMcpServer:
INSERT OR REPLACE INTO McpServerEntity(
    id, displayName, baseUrl, enabled, headersJson, lastSyncToolsJson, lastSyncError, lastSyncAt, deploymentKind, startCommand, linkStatus, wireKind
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getMcpServer:
SELECT * FROM McpServerEntity WHERE id = ?;

getAllMcpServers:
SELECT * FROM McpServerEntity ORDER BY displayName ASC;

deleteMcpServer:
DELETE FROM McpServerEntity WHERE id = ?;

insertMcpToolBinding:
INSERT OR REPLACE INTO McpToolBindingEntity(
    id, serverId, mcpToolName, description, inputSchemaJson, enabled
)
VALUES (?, ?, ?, ?, ?, ?);

getMcpBindingsForServer:
SELECT * FROM McpToolBindingEntity WHERE serverId = ? ORDER BY mcpToolName ASC;

getAllMcpBindings:
SELECT * FROM McpToolBindingEntity ORDER BY serverId, mcpToolName ASC;

deleteMcpBinding:
DELETE FROM McpToolBindingEntity WHERE id = ?;

deleteMcpBindingsForServer:
DELETE FROM McpToolBindingEntity WHERE serverId = ?;

-- Локальный Graylog: URL веб-UI и опциональная команда запуска (docker compose и т.д.)
CREATE TABLE IF NOT EXISTS GraylogSettingsEntity (
    id TEXT NOT NULL PRIMARY KEY,
    webUrl TEXT NOT NULL,
    startCommand TEXT NOT NULL DEFAULT ''
);

getGraylogSettings:
SELECT * FROM GraylogSettingsEntity WHERE id = 'default';

upsertGraylogSettings:
INSERT OR REPLACE INTO GraylogSettingsEntity(id, webUrl, startCommand)
VALUES ('default', ?, ?);

-- Глобальные настройки пайплайна RAG (JSON RagRetrievalConfig)
CREATE TABLE IF NOT EXISTS RagPipelineSettingsEntity (
    id TEXT NOT NULL PRIMARY KEY,
    configJson TEXT NOT NULL
);

getRagPipelineSettings:
SELECT * FROM RagPipelineSettingsEntity WHERE id = 'default';

upsertRagPipelineSettings:
INSERT OR REPLACE INTO RagPipelineSettingsEntity(id, configJson)
VALUES ('default', ?);

-- RAG: документы и чанки с эмбеддингами (BLOB float32 LE)
CREATE TABLE IF NOT EXISTS RagDocumentEntity (
    id TEXT NOT NULL PRIMARY KEY,
    title TEXT NOT NULL,
    sourceFileName TEXT NOT NULL,
    sourcePath TEXT NOT NULL,
    ollamaModel TEXT NOT NULL,
    chunkSize INTEGER NOT NULL,
    overlap INTEGER NOT NULL,
    chunkStrategy TEXT NOT NULL,
    createdAt INTEGER NOT NULL,
    fullText TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS RagChunkEntity (
    id TEXT NOT NULL PRIMARY KEY,
    documentId TEXT NOT NULL,
    chunkIndex INTEGER NOT NULL,
    startOffset INTEGER NOT NULL,
    endOffset INTEGER NOT NULL,
    text TEXT NOT NULL,
    embeddingBlob BLOB NOT NULL,
    FOREIGN KEY(documentId) REFERENCES RagDocumentEntity(id) ON DELETE CASCADE
);

CREATE INDEX IF NOT EXISTS idx_rag_chunk_document ON RagChunkEntity(documentId);

insertRagDocument:
INSERT OR REPLACE INTO RagDocumentEntity(
    id, title, sourceFileName, sourcePath, ollamaModel, chunkSize, overlap, chunkStrategy, createdAt, fullText
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getRagDocumentBySource:
SELECT * FROM RagDocumentEntity WHERE sourceFileName = ? AND sourcePath = ? LIMIT 1;

-- Тот же источник: только точное совпадение имени файла и нормализованного пути.
-- Не использовать sourcePath = id в этом DELETE: для строк с путём = id документа условие истинно на каждой строке
-- и при повторной вставке удалялись бы все такие документы с тем же sourceFileName.
selectRagDocumentIdsForSameFileSource:
SELECT id FROM RagDocumentEntity WHERE sourceFileName = ? AND sourcePath = ?;

deleteRagDocumentsForSameFileSource:
DELETE FROM RagDocumentEntity WHERE sourceFileName = ? AND sourcePath = ?;

-- Старые строки, где sourcePath совпадал с id; вызывать только при вставке документа с реальным путём к файлу (есть / или \).
deleteRagDocumentsLegacySourcePathEqualsIdForFileName:
DELETE FROM RagDocumentEntity WHERE sourceFileName = ? AND sourcePath = id;

insertRagChunk:
INSERT OR REPLACE INTO RagChunkEntity(
    id, documentId, chunkIndex, startOffset, endOffset, text, embeddingBlob
)
VALUES (?, ?, ?, ?, ?, ?, ?);

getAllRagDocuments:
SELECT * FROM RagDocumentEntity ORDER BY createdAt DESC;

getRagDocument:
SELECT * FROM RagDocumentEntity WHERE id = ?;

getChunksForRagDocument:
SELECT * FROM RagChunkEntity WHERE documentId = ? ORDER BY chunkIndex ASC;

deleteRagDocument:
DELETE FROM RagDocumentEntity WHERE id = ?;

-- RAG retrieval: чанки с метаданными документа для поиска по эмбеддингам
getAllRagChunksWithDocuments:
SELECT
    c.id AS chunkId,
    c.documentId,
    c.chunkIndex,
    c.startOffset,
    c.endOffset,
    c.text AS chunkText,
    c.embeddingBlob,
    d.ollamaModel,
    d.title AS documentTitle,
    d.sourceFileName
FROM RagChunkEntity c
INNER JOIN RagDocumentEntity d ON c.documentId = d.id;
