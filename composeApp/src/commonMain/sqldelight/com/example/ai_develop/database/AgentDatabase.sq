import com.example.ai_develop.domain.AgentStage;
import kotlin.Boolean;

CREATE TABLE IF NOT EXISTS AgentStateEntity (
    agentId TEXT NOT NULL PRIMARY KEY,
    name TEXT NOT NULL DEFAULT '',
    systemPrompt TEXT NOT NULL DEFAULT 'You are a helpful assistant.',
    temperature REAL NOT NULL DEFAULT 0.7,
    maxTokens INTEGER NOT NULL DEFAULT 2000,
    stopWord TEXT NOT NULL DEFAULT '',
    currentStage TEXT AS AgentStage NOT NULL DEFAULT 'PLANNING',
    currentStepId TEXT,
    planJson TEXT NOT NULL, -- JSON AgentPlan
    memoryStrategyJson TEXT NOT NULL DEFAULT '', -- JSON ChatMemoryStrategy
    workingMemoryJson TEXT NOT NULL DEFAULT '' -- JSON WorkingMemory
);

CREATE TABLE IF NOT EXISTS ProfileEntity (
    agentId TEXT NOT NULL PRIMARY KEY,
    preferences TEXT NOT NULL,
    constraints TEXT NOT NULL,
    memoryModelProviderJson TEXT -- JSON LLMProvider
);

CREATE TABLE IF NOT EXISTS InvariantEntity (
    id TEXT NOT NULL PRIMARY KEY,
    agentId TEXT NOT NULL,
    rule TEXT NOT NULL,
    stage TEXT AS AgentStage NOT NULL,
    isActive INTEGER AS Boolean NOT NULL DEFAULT 1,
    FOREIGN KEY(agentId) REFERENCES AgentStateEntity(agentId) ON DELETE CASCADE
);

CREATE TABLE IF NOT EXISTS AgentMessageEntity (
    id TEXT NOT NULL PRIMARY KEY,
    agentId TEXT NOT NULL,
    stage TEXT AS AgentStage NOT NULL,
    stepId TEXT,
    role TEXT NOT NULL,
    content TEXT NOT NULL,
    timestamp INTEGER NOT NULL,
    FOREIGN KEY(agentId) REFERENCES AgentStateEntity(agentId) ON DELETE CASCADE
);

-- Queries
saveAgentState:
INSERT OR REPLACE INTO AgentStateEntity(
    agentId, name, systemPrompt, temperature, maxTokens, stopWord,
    currentStage, currentStepId, planJson, memoryStrategyJson, workingMemoryJson
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getAgentState:
SELECT * FROM AgentStateEntity WHERE agentId = ?;

getAllAgents:
SELECT * FROM AgentStateEntity;

saveProfile:
INSERT OR REPLACE INTO ProfileEntity(agentId, preferences, constraints, memoryModelProviderJson)
VALUES (?, ?, ?, ?);

getProfile:
SELECT * FROM ProfileEntity WHERE agentId = ?;

insertInvariant:
INSERT OR REPLACE INTO InvariantEntity(id, agentId, rule, stage, isActive)
VALUES (?, ?, ?, ?, ?);

getInvariantsForStage:
SELECT * FROM InvariantEntity WHERE agentId = ? AND stage = ? AND isActive = 1;

insertMessage:
INSERT INTO AgentMessageEntity(id, agentId, stage, stepId, role, content, timestamp)
VALUES (?, ?, ?, ?, ?, ?, ?);

getMessagesForAgent:
SELECT * FROM AgentMessageEntity WHERE agentId = ? ORDER BY timestamp ASC;

deleteAgent:
DELETE FROM AgentStateEntity WHERE agentId = ?;
